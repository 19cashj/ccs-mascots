---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/gallery.css';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
const baseUrl = import.meta.env.BASE_URL;
const reader = createReader(process.cwd(), keystaticConfig);

const galleries = await reader.singletons.galleries.read();
const images: string[] = (galleries?.galleryPageImages ?? [])
  .map((item) => `${baseUrl}${item.image.replace(/^\//, '')}`);

---

<Base title="Gallery – CCS Mascots">

  <Nav />

  <main class="gallery-page">

    <header class="gallery-header">
      <h1 class="gallery-title">Gallery</h1>
      <div class="gallery-header-rule"></div>
    </header>

    <div class="gallery-grid">
      {images.map((src, i) => (
        <div class="gallery-grid-item is-loading">
          <img
            src={src}
            alt={`CCS Mascots fursuit ${i + 1}`}
            class="gallery-grid-img is-loading"
            loading="lazy"
            decoding="async"
            onload="this.classList.remove('is-loading'); this.classList.add('is-loaded'); this.parentElement?.classList.remove('is-loading'); this.parentElement?.classList.add('has-img');"
          />
        </div>
      ))}
    </div>

  </main>

  <script>
    window.addEventListener('load', () => {
      const grid = document.querySelector('.gallery-grid') as HTMLElement;
      const items = Array.from(grid.querySelectorAll('.gallery-grid-item')) as HTMLElement[];

      // Detect columns by finding distinct left positions.
      const lefts = [...new Set(items.map((el) => Math.round(el.getBoundingClientRect().left)))]
        .sort((a, b) => a - b);

      // Assign animation-delay based on which column each item is in.
      items.forEach((item) => {
        const col = lefts.indexOf(Math.round(item.getBoundingClientRect().left));
        item.style.animationDelay = `${col * 100}ms`;
      });

      // Start all animations.
      items.forEach((item) => item.classList.add('go'));

      // Handle cached images so they don't stay hidden.
      const imgs = Array.from(grid.querySelectorAll('.gallery-grid-img')) as HTMLImageElement[];
      imgs.forEach((img) => {
        if (img.complete && img.naturalWidth > 0) {
          img.classList.remove('is-loading');
          img.classList.add('is-loaded');
          img.parentElement?.classList.remove('is-loading');
          img.parentElement?.classList.add('has-img');
        }
      });
    });
  </script>

  <Footer />

</Base>
