---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import MarqueeGallery from '../components/MarqueeGallery.astro';
import '../styles/global.css';
 
const galleryImages: string[] = [
  '/images/imgi_4_650395250_25888888610794866_8401919460525743794_n.jpg',
  '/images/imgi_4_658212590_18414597787192824_3964572917485297192_n.jpg',
  '/images/imgi_6_645515842_1558910825408559_8876760470022643830_n.jpg',
  '/images/imgi_8_649224438_18092107570873773_3593664648647826824_n.jpg',
  '/images/imgi_10_627173060_18553405954010839_8532855200301839239_n.jpg',
  '/images/imgi_12_611723605_18547309051010839_3812523570113101312_n.jpg',
  '/images/imgi_13_590402301_18540007450010839_1918693086465875745_n.jpg',
  '/images/imgi_15_542759485_1331610202302030_3496552279551058264_n.jpg',
  '/images/imgi_16_541472509_18521286889010839_4740806053630733928_n (1).jpg',
  '/images/imgi_20_651144389_18140545483495878_1572600906342957209_n.jpg',
  '/images/imgi_22_650999120_18106227037885867_9219586718479070233_n.jpg',
  '/images/imgi_23_518254492_18511792132010839_5498531674267893422_n (1).jpg',
  '/images/imgi_25_649794838_18057855314408296_3138593465742726697_n.jpg',
  '/images/imgi_27_650360370_18146337472475094_8552298531154662153_n.jpg',
  '/images/imgi_36_651096719_18170759227394331_1460760374152369830_n.jpg',
  '/images/imgi_49_617211528_18087791396024410_6348247363512441032_n.jpg',
  '/images/imgi_51_656848668_18158051332435040_455934051480583350_n.jpg',
  '/images/imgi_55_654997398_18320830642264926_3996230597930177189_n.jpg',
  '/images/imgi_58_650253504_18095138905823143_5277713311563687253_n.jpg',
  '/images/imgi_59_656042286_18336611983171779_436269229251073727_n.jpg',
  '/images/imgi_63_530042659_734694479359491_2751720454806985734_n.jpg',
  '/images/imgi_66_655296111_18412788157133164_8303497130303952745_n.jpg',
];
 
const tiers = [
  { name: 'Heads',                price: '$1600+', image: '/images/price-heads.jpg'       },
  { name: 'Partial Suits',        price: '$2200+', image: '/images/price-partials.jpg'    },
  { name: 'Plantigrade Fursuits', price: '$3200+', image: '/images/price-plantigrade.jpg' },
  { name: 'Digitigrade Fursuits', price: '$3700+', image: '/images/price-digitigrade.jpg' },
];
---
 
<Base title="CCS Mascots – Costumes and Fursuits, Maine Made Your Way">
 
  <Nav />
 
  <!-- ── HERO ── -->
  <section class="hero">
 
    <div class="hero-left">
      <div class="logo-wrapper">
        <img src="/images/logo.webp" alt="CCS Mascots Logo" />
      </div>
 
      <div class="hero-headline">
        <span class="line-purple">Costumes and</span>
        <span class="line-purple">Fursuits, Maine</span>
        <span class="line-pink">Made Your Way</span>
      </div>
 
      <p class="hero-tagline">
        Affordable, Durable, Adorable Custom Costumes made just for you!
      </p>
 
      <div class="hero-buttons">
        <a href="#pricing" class="btn">Get a Quote</a>
        <a href="/terms"   class="btn">Terms of Service</a>
      </div>
    </div>
 
    <MarqueeGallery images={galleryImages} />
 
  </section>
 
  <!-- ── PRICING ── -->
  <section class="pg" id="pricing">
 
    <h2 class="pg-title">Costs</h2>
    <div class="pg-rule"></div>
 
    <div class="pg-grid">
      {tiers.map(tier => (
        <div class="pg-card">
          <p class="pg-name">{tier.name}</p>
          <div class="pg-img-wrap">
            <img src={tier.image} alt={tier.name} class="pg-img" />
          </div>
          <div class="pg-pricing">
            <p class="pg-label">Starting at</p>
            <p class="pg-price">{tier.price}</p>
          </div>
        </div>
      ))}
    </div>
 
    <p class="pg-note">
      <strong>Please note:</strong> prices listed are for basic builds with no added extras.<br />
      Costs may increase to reflect added details and design difficulty.
    </p>

    <div class="pg-cta">
      <a href="/price-guide" class="btn">Full Price Guide</a>
    </div>

  </section>

  <!-- ── ABOUT ── -->
  <section class="about" id="about">
    <div class="about-inner">

      <div class="about-text">
        <h2 class="about-heading">About Us</h2>
        <div class="about-rule"></div>
        <p class="about-body">
          Local to the Maine Furry Community since 2014, we have prided ourselves on providing
          Quality, Affordable Mascot Style Costumes. We use innovative methods such as 3D modeling
          and printing, as well as the finest fabrics and materials, to create a comfortable and
          durable costume that will last for years to come.
        </p>
      </div>

      <div class="about-img-wrap">
        <img
          src="/images/about-us.jpg"
          alt="CCS Mascots group photo"
          class="about-img"
        />
      </div>

    </div>
  </section>

  <!-- ── REVIEWS ── -->
  <section class="reviews" id="reviews">
    <h2 class="reviews-title">Our Happy Customers</h2>
    <div class="reviews-rule"></div>

    <div class="reviews-carousel">
      <button class="reviews-arrow reviews-prev" aria-label="Previous review">&#8249;</button>

      <div class="reviews-track-wrap">
        <div class="reviews-track">

          <div class="review-slide">
            <div class="review-img-wrap">
              <img src="/images/imgi_15_542759485_1331610202302030_3496552279551058264_n.jpg" alt="Customer fursuit" class="review-img" />
            </div>
            <div class="review-content">
              <span class="review-qdeco review-qdeco--open">&ldquo;</span>
              <blockquote class="review-quote">Super cute fursuit, amazing quality, great ventilation and vision. The seller was super kind and amazing to work with.</blockquote>
              <span class="review-qdeco review-qdeco--close">&rdquo;</span>
              <div class="review-stars">★★★★★</div>
            </div>
          </div>

          <div class="review-slide">
            <div class="review-img-wrap">
              <img src="/images/imgi_8_649224438_18092107570873773_3593664648647826824_n.jpg" alt="Customer fursuit" class="review-img" />
            </div>
            <div class="review-content">
              <span class="review-qdeco review-qdeco--open">&ldquo;</span>
              <blockquote class="review-quote">Absolutely love my suit! The craftsmanship is incredible and it arrived faster than expected. Will definitely be ordering again.</blockquote>
              <span class="review-qdeco review-qdeco--close">&rdquo;</span>
              <div class="review-stars">★★★★★</div>
            </div>
          </div>

          <div class="review-slide">
            <div class="review-img-wrap">
              <img src="/images/imgi_22_650999120_18106227037885867_9219586718479070233_n.jpg" alt="Customer fursuit" class="review-img" />
            </div>
            <div class="review-content">
              <span class="review-qdeco review-qdeco--open">&ldquo;</span>
              <blockquote class="review-quote">Exceeded all my expectations. Communication was excellent throughout the whole process and the end result was stunning.</blockquote>
              <span class="review-qdeco review-qdeco--close">&rdquo;</span>
              <div class="review-stars">★★★★★</div>
            </div>
          </div>

        </div>
      </div>

      <button class="reviews-arrow reviews-next" aria-label="Next review">&#8250;</button>
    </div>

    <div class="reviews-dots"></div>
  </section>

  <script>
    const track = document.querySelector('.reviews-track') as HTMLElement;
    const slides = Array.from(document.querySelectorAll('.review-slide')) as HTMLElement[];
    const dotsWrap = document.querySelector('.reviews-dots') as HTMLElement;
    let current = 0;

    const dots = slides.map((_, i) => {
      const d = document.createElement('button');
      d.className = 'reviews-dot' + (i === 0 ? ' active' : '');
      d.setAttribute('aria-label', `Review ${i + 1}`);
      d.addEventListener('click', () => goTo(i));
      dotsWrap.appendChild(d);
      return d;
    });

    function goTo(n: number) {
      current = (n + slides.length) % slides.length;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    document.querySelector('.reviews-prev')!.addEventListener('click', () => goTo(current - 1));
    document.querySelector('.reviews-next')!.addEventListener('click', () => goTo(current + 1));
  </script>

  <!-- ── CTA BANNER ── -->
  <section class="cta-banner">
    <img src="/images/cta-banner.jpg" alt="" class="cta-bg" aria-hidden="true" />
    <div class="cta-overlay">
      <h2 class="cta-heading">Ready to Bring Your Character to Life?</h2>
      <p class="cta-sub">Custom fursuits built with love, right here in Maine.</p>
      <a href="#pricing" class="btn cta-btn">Get a Quote</a>
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="footer">
    <div class="footer-inner">

      <p class="footer-tagline">Delivering smiles to the Furry Community and<br />Costume Enthusiasts alike since 2014</p>

      <div class="footer-contact">
        <p>Augusta ME, 04330</p>
        <a href="mailto:CraftyWolf@ccsmascots.net">CraftyWolf@ccsmascots.net</a>
      </div>

      <nav class="footer-links">
        <a href="#">Facebook</a>
        <a href="#">Instagram</a>
        <a href="#">TikTok</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="/privacy">Privacy and Cookies</a>
      </nav>

    </div>
  </footer>

</Base>
