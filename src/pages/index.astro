const tiers = [
  {
    name: 'Foam Carved Fursuit Head',
    price: '$1600+',
    image: '/images/price-heads.jpg',
    description: 'Our foam-based heads are meticulously custom carved and feature a full neoprene scuba-type lining for exceptional comfort and fit. The 3D printed plastic eyes are designed with waterproof printed mesh, ensuring effortless cleaning and exceptional durability.',
  },
  {
    name: '3D Print Base Fursuit Head',
    price: '$1600+',
    image: '/images/price-heads3d.jpg',
    description: 'With a 3D printed base, this fantastic option caters to individuals who appreciate a sturdy structure. It comes with the choice of semi-realistic or toony style bases, offering delightful customization opportunities.',
  },
  {
    name: 'Fursuit Mini-Partial',
    price: '$2200+',
    image: '/images/price-minipartial.jpg',
    description: 'Our mini-partials offer you the perfect opportunity to showcase your unique character with style. This top-notch option includes a headpiece, fully lined costume paws, and a fabulous fluffy tail, all designed to truly immerse you in your character.',
  },
  {
    name: 'Fursuit ¾ Partial',
    price: '$2600+',
    image: '/images/price-3quarter.jpg',
    description: 'Are you seeking to elevate your character\'s appearance? Our 3/4 Fursuit option goes above and beyond, incorporating arm sleeves and feet paws to enhance the overall look.',
  },
  {
    name: 'Plantigrade Fullbody Fursuit',
    price: '$3200+',
    image: '/images/price-plantigrade.jpg',
    description: 'Just one step away from achieving the ultimate fursuit look. Our full body setup includes a body suit to create an absolutely complete and impressive appearance.',
  },
  {
    name: 'Digitigrade Full Body Fursuit',
    price: '$3700+',
    image: '/images/price-digitigrade2.jpg',
    description: 'The Ultimate Look! Our full-body padded bodysuits are included in the package to help you achieve a beautifully anatomically correct animal appearance. They feature convenient zipper pockets for effortless cleaning, travel, and stuffing replacement. Additionally, we offer the option to add outside pockets upon request.',
  },
];
---
 
<Base title="CCS Mascots – Costumes and Fursuits, Maine Made Your Way">
 
  <Nav />
 
  <!-- ── HERO ── -->
  <section class="hero">
 
    <div class="hero-left">
      <div class="logo-wrapper">
        <img src="/images/logo.webp" alt="CCS Mascots Logo" />
      </div>
 
      <div class="hero-headline">
        <span class="line-purple">Costumes and</span>
        <span class="line-purple">Fursuits, Maine</span>
        <span class="line-pink">Made Your Way</span>
      </div>
 
      <p class="hero-tagline">
        Affordable, Durable, Adorable Custom Costumes made just for you!
      </p>
 
      <div class="hero-buttons">
        <a href="#pricing" class="btn">Get a Quote</a>
        <a href="/terms"   class="btn">Terms of Service</a>
      </div>
    </div>
 
    <MarqueeGallery images={galleryImages} />
 
  </section>
 
  <!-- ── PRICING ── -->
  <section class="pg" id="pricing">
    <div class="pg-page">

      <header class="pg-header">
        <h1 class="pg-header-title">Price Guide</h1>
        <div class="pg-header-rule"></div>
      </header>

      <div class="pg-list">
        {tiers.map((tier) => (
          <article class="pg-item">
            <div class="pg-item-img-wrap">
              <img src={tier.image} alt={tier.name} class="pg-item-img" />
            </div>
            <div class="pg-item-body">
              <h2 class="pg-item-name">{tier.name}</h2>
              <div class="pg-item-price-wrap">
                <span class="pg-item-from">Starting at</span>
                <span class="pg-item-price">{tier.price}</span>
              </div>
              <p class="pg-item-desc">{tier.description}</p>
            </div>
          </article>
        ))}
      </div>

      <aside class="pg-disclaimer">
        <strong>Please note:</strong> Prices listed are for basic with no added extras. 
        Costs may increase to reflect added details and design difficulty.
      </aside>

    </div>
  </section>

  <!-- ── ABOUT ── -->
  <section class="about" id="about">
    <div class="about-inner">

      <div class="about-text">
        <h2 class="about-heading">About Us</h2>
        <div class="about-rule"></div>
        <p class="about-body">
          Local to the Maine Furry Community since 2014, we have prided ourselves on providing
          Quality, Affordable Mascot Style Costumes. We use innovative methods such as 3D modeling
          and printing, as well as the finest fabrics and materials, to create a comfortable and
          durable costume that will last for years to come.
        </p>
      </div>

      <div class="about-img-wrap">
        <img
          src="/images/about-us.jpg"
          alt="CCS Mascots group photo"
          class="about-img"
        />
      </div>

    </div>
  </section>

  <!-- ── CTA BANNER ── -->
  <section class="cta-banner">
    <img src="/images/cta-banner.jpg" alt="" class="cta-bg" aria-hidden="true" />
    <div class="cta-overlay">
      <h2 class="cta-heading">Ready to Bring Your Character to Life?</h2>
      <p class="cta-sub">Custom fursuits built with love, right here in Maine.</p>
      <a href="#pricing" class="btn cta-btn">Get a Quote</a>
    </div>
  </section>

  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.35, rootMargin: '0px 0px -80px 0px' }
    );
    document.querySelectorAll('.pg-item, .about-text, .about-img-wrap, .cta-banner').forEach((el) => observer.observe(el));
  </script>

  <Footer />

</Base>
