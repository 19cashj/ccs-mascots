---
import MarqueeGallery from './MarqueeGallery.astro';
import '../styles/hero.css';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
const baseUrl = import.meta.env.BASE_URL;
const reader = createReader(process.cwd(), keystaticConfig);
interface Props {
  content?: {
    heroHeadlineLine1?: string;
    heroHeadlineLine2?: string;
    heroHeadlineLine3?: string;
    heroTagline?: string;
    heroPrimaryButtonText?: string;
    heroPrimaryButtonUrl?: string;
    heroSecondaryButtonText?: string;
    heroSecondaryButtonUrl?: string;
  } | null;
}
const { content } = Astro.props as Props;

const galleries = await reader.singletons.galleries.read();
const galleryImages: string[] = (galleries?.marqueeGalleryImages ?? [])
  .map((item) => `${baseUrl}${item.image.replace(/^\//, '')}`);
---

<section class="hero">

  <div class="hero-left">
    <div class="logo-wrapper">
      <img
        src={`${baseUrl}images/logo.webp`}
        alt="CCS Mascots Logo"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>

    <div class="hero-headline">
      <span class="line-purple">{content?.heroHeadlineLine1 ?? 'Costumes and'}</span>
      <span class="line-purple">{content?.heroHeadlineLine2 ?? 'Fursuits, Maine'}</span>
      <span class="line-pink">{content?.heroHeadlineLine3 ?? 'Made Your Way'}</span>
    </div>

    <p class="hero-tagline">
      {content?.heroTagline ?? 'Affordable, Durable, Adorable Custom Costumes made just for you!'}
    </p>

    <div class="hero-buttons">
      <a href={content?.heroPrimaryButtonUrl ?? 'https://docs.google.com/forms/d/e/1FAIpQLSdvfWdapp_bzKXglitzdxh65CiGRf7PifEItHlmHBU5zKwX_Q/viewform'} target="_blank" rel="noopener noreferrer" class="btn">{content?.heroPrimaryButtonText ?? 'Get a Quote'}</a>
      <a href={content?.heroSecondaryButtonUrl ?? 'https://docs.google.com/document/d/1TyKMxOpOX514vxL4cl_tLCc27aMnGeRZZWeNfWybef0/edit?tab=t.0'} target="_blank" rel="noopener noreferrer" class="btn">{content?.heroSecondaryButtonText ?? 'Terms of Service'}</a>
    </div>
  </div>

  <MarqueeGallery images={galleryImages} />

</section>
