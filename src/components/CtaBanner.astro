---
import '../styles/cta.css';
const baseUrl = import.meta.env.BASE_URL;
---

<section class="cta-banner">
  <img src={`${baseUrl}images/cta-banner.jpg`} alt="" class="cta-bg" aria-hidden="true" />
  <div class="cta-overlay">
    <h2 class="cta-heading">Ready to Bring Your Character to Life?</h2>
    <p class="cta-sub">Custom fursuits built with love, right here in Maine.</p>
    <a href="https://docs.google.com/forms/d/e/1FAIpQLSdvfWdapp_bzKXglitzdxh65CiGRf7PifEItHlmHBU5zKwX_Q/viewform" target="_blank" rel="noopener noreferrer" class="btn cta-btn">Get a Quote</a>
  </div>
</section>
