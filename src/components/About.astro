---
import '../styles/about.css';
---

<section class="about" id="about">
  <div class="about-inner">

    <div class="about-text">
      <h2 class="about-heading">About Us</h2>
      <div class="about-rule"></div>
      <p class="about-body">
        Local to the Maine Furry Community since 2014, we have prided ourselves on providing
        Quality, Affordable Mascot Style Costumes. We use innovative methods such as 3D modeling
        and printing, as well as the finest fabrics and materials, to create a comfortable and
        durable costume that will last for years to come.
      </p>
    </div>

    <div class="about-img-wrap">
      <img
        src="/images/about-us.jpg"
        alt="CCS Mascots group photo"
        class="about-img"
      />
    </div>

  </div>
</section>
