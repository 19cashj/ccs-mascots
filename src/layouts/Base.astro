---
import { Image } from 'astro:assets';
import bgImage from '../images/logan-voss-ZnKC0csB1WY-unsplash.jpg';

interface Props {
  title?: string;
}
const { title = 'CCS Mascots - Costumes and Fursuits, Maine' } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;900&family=Fredoka+One&family=Raleway:wght@400;700;900&family=Catamaran:wght@400;700;900&family=Open+Sans:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/x-icon" href={`${baseUrl}favicon.ico?v=2`} />
    <link rel="shortcut icon" type="image/x-icon" href={`${baseUrl}favicon.ico?v=2`} />
  </head>
  <body>
    <Image src={bgImage} alt="" class="site-bg" aria-hidden="true" />
    <slot />
  </body>
</html>
